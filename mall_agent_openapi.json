{
  "openapi": "3.0.0",
  "info": {
    "title": "Mall Assistant Data API",
    "description": "Provides real-time information about mall deals, store offers, events, user history, and multi-mode directions.",
    "version": "1.3.0"
  },
  "servers": [
    {
      "url": "https://mall-agent-production.up.railway.app/"
    }
  ],
  "paths": {
    "/deals": {
      "get": {
        "summary": "Get Mall Deals",
        "operationId": "getDeals",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/events": {
      "get": {
        "summary": "Get Mall Events",
        "operationId": "getEvents",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/user": {
      "get": {
        "summary": "Find User",
        "operationId": "getUser",
        "parameters": [
          { "name": "identifier", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Register User",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserCreate" } } }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/orders": {
      "get": {
        "summary": "Get Orders",
        "operationId": "getOrders",
        "parameters": [
          { "name": "phone_number", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/directions": {
      "get": {
        "summary": "Get Mall Directions (Driving & Walking)",
        "operationId": "getDirections",
        "parameters": [
          { "name": "origin", "in": "query", "required": true, "schema": { "type": "string" }, "description": "User's current location or coordinates (lat,lon)." },
          { "name": "destination", "in": "query", "schema": { "type": "string" }, "description": "Defaulted to Ikeja City Mall if left blank." }
        ],
        "responses": {
          "200": {
            "description": "Multi-mode route summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "routes": {
                      "type": "object",
                      "properties": {
                        "driving": { "$ref": "#/components/schemas/Route" },
                        "walking": { "$ref": "#/components/schemas/Route" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserCreate": {
        "type": "object",
        "required": ["name", "phone_number", "email"],
        "properties": {
          "name": { "type": "string" },
          "phone_number": { "type": "string" },
          "email": { "type": "string" },
          "last_activity": { "type": "string" }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "distance_meters": { "type": "number" },
          "duration_seconds": { "type": "number" },
          "instructions": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
